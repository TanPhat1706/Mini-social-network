# Vite chỉ load file .env ở thư mục này (cùng cấp vite.config.ts), KHÔNG đọc src/.env
#
# Backend — khi dùng ngrok: `ngrok http 8080`, copy URL https và cập nhật bên dưới.
# Local:
# VITE_API_BASE_URL=http://alb-minisocial-1557209446.ap-southeast-1.elb.amazonaws.com
VITE_API_BASE_URL=http://localhost:8080
VITE_API_AUTH_ENDPOINT=/api/auth
VITE_API_URL=
VITE_API_TIMEOUT=10000

# App metadata
VITE_APP_NAME=Mini Social Network
VITE_APP_VERSION=1.0.0
#
# Ngrok:
# VITE_API_BASE_URL=https://0781-2405-4802-9818-7a50-14bd-b41d-b5b-af23.ngrok-free.app
# VITE_API_AUTH_ENDPOINT=/api/auth
# VITE_API_URL=https://0781-2405-4802-9818-7a50-14bd-b41d-b5b-af23.ngrok-free.app/api/auth