# ========== API Configuration ==========
# Base URL for the backend API (no trailing slash)
VITE_API_BASE_URL=http://localhost:8080
# Auth endpoint path (used when VITE_API_URL is not set)
VITE_API_AUTH_ENDPOINT=/api/auth
# Full API auth URL as a fallback if you want to override base + endpoint
VITE_API_URL=
# API request timeout in milliseconds
VITE_API_TIMEOUT=10000

# ========== App Configuration ==========
VITE_APP_NAME=Mini Social Network
VITE_APP_VERSION=1.0.0
