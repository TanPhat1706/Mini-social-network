<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Thư mục log -->
    <property name="LOG_PATH" value="logs"/>

    <!-- ================= CONSOLE ================= -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- JSON để dễ demo ELK -->
            <pattern>
                {"time":"%d{yyyy-MM-dd'T'HH:mm:ss}",
                "level":"%level",
                "msg":"%msg"}%n
            </pattern>
        </encoder>
    </appender>

    <!-- ================= SECURITY FILE ================= -->
    <appender name="SECURITY_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/security_audit.log</file>

        <!-- rotate theo ngày -->
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/security_audit.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>7</maxHistory>
        </rollingPolicy>

        <!-- JSON format -->
        <encoder>
            <pattern>
                {"time":"%d{yyyy-MM-dd'T'HH:mm:ss}",
                "level":"%level",
                "type":"SECURITY",
                "msg":"%msg"}%n
            </pattern>
        </encoder>

        <!-- chỉ ghi WARN trở lên -->
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>WARN</level>
        </filter>
    </appender>

    <!-- ================= APP FILE ================= -->
    <appender name="APP_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_PATH}/app.log</file>

        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_PATH}/app.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>7</maxHistory>
        </rollingPolicy>

        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Logger riêng cho SECURITY -->
    <logger name="SECURITY" level="WARN" additivity="false">
        <appender-ref ref="SECURITY_FILE"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- Root -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="APP_FILE"/>
    </root>

</configuration>