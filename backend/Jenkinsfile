pipeline {
    agent any

    environment {
        AWS_ACCOUNT_ID = "295662439915"
        AWS_REGION     = "ap-southeast-1"
        ECR_REPO_NAME  = "minisocial-backend"
        IMAGE_TAG      = "latest" 
        ECR_REGISTRY   = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
        IMAGE_URI      = "${ECR_REGISTRY}/${ECR_REPO_NAME}:${IMAGE_TAG}"
    }

    stages {
        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Run Unit Tests') {
            steps {
                dir('backend') {
                    // 🟢 ĐỔI sh -> bat
                    bat 'mvn clean test' 
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('backend') {
                    echo "Building Docker image..."
                    // 🟢 ĐỔI sh -> bat
                    bat "docker build -t ${IMAGE_URI} ."
                }
            }
        }

        stage('Push to AWS ECR') {
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-credentials', 
                    accessKeyVariable: 'AWS_ACCESS_KEY_ID',
                    secretKeyVariable: 'AWS_SECRET_ACCESS_KEY'
                ]]) {
                    echo "Logging into AWS ECR..."
                    // 🟢 ĐỔI sh -> bat. 
                    // Lưu ý ở Windows, dùng bat với block 1 dòng thường an toàn hơn dùng """ nhiều dòng
                    bat "aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${ECR_REGISTRY}"
                    
                    echo "Pushing image to ECR..."
                    bat "docker push ${IMAGE_URI}"
                }
            }
        }
    }

    post {
        success {
            echo "🎉 TUYỆT VỜI! Đã test, build và push thành công lên AWS ECR!"
        }
        failure {
            echo "❌ CÓ LỖI XẢY RA! Hãy vào kiểm tra lại log nhé!"
        }
        always {
            // 🟢 ĐỔI sh -> bat
            bat "docker image prune -f"
        }
    }
}